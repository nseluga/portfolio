---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { SECTIONS } from '../../data/site';
import { getCollection } from 'astro:content';

const section = SECTIONS.startups;

// Get all projects and filter by section
const allProjects = await getCollection('projects');
const sectionProjects = allProjects
  .filter((project) => project.data.section === 'startups' && !project.data.draft)
  .sort((a, b) => (b.data.order || 0) - (a.data.order || 0));
---

<BaseLayout
  title={section.title}
  description={section.intro}
  currentPath="/startups"
>
  <div class="py-12">
    <h1 class="text-4xl font-bold mb-4">{section.title}</h1>
    <p class="text-lg text-muted mb-12 max-w-2xl">
      {section.intro}
    </p>

    {sectionProjects.length > 0 ? (
      <section class="grid gap-8">
        {sectionProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            summary={project.data.summary}
            href={`/${project.data.section}/${project.slug}`}
            thumbnail={project.data.thumbnail}
          />
        ))}
      </section>
    ) : (
      <section class="space-y-6">
        <p class="text-muted italic">Projects coming soon.</p>
      </section>
    )}
  </div>
</BaseLayout>
